{
  "resourceType": "StructureMap",
  "id": "ccda-procedure-to-procedure",
  "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureMap/ccda-procedure-to-procedure",
  "version": "0.1.0",
  "name": "CCDAProcedureToProcedure",
  "title": "C-CDA Procedure Entry to HITC Canonical Procedure",
  "status": "draft",
  "experimental": true,
  "date": "2026-07-21",
  "publisher": "Xinyang Li",
  "description": "XPath-extracted C-CDA procedure entry to Procedure structure map.",
  "copyright": "© 2026 Xinyang Li. Draft technical specification.",
  "purpose": "Implements reusable structural mapping for the Procedures section.",
  "structure": [
    {
      "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureDefinition/HITCCCDAEntry",
      "mode": "source",
      "alias": "CCDAEntry",
      "documentation": "Normalized logical input model for the source segment or C-CDA entry."
    },
    {
      "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureDefinition/hitc-canonical-procedure",
      "mode": "target",
      "alias": "Procedure",
      "documentation": "Strict-at-core canonical FHIR R4 target profile."
    }
  ],
  "group": [
    {
      "name": "CCDAProcedureToProcedure",
      "typeMode": "types",
      "documentation": "Phase 1 structural mapping. Terminology translation, UCUM normalization, ISO 8601 normalization, and value-set validation occur in Phase 2 unless explicitly invoked by a translate rule.",
      "input": [
        {
          "name": "src",
          "type": "HITCCCDAEntry",
          "mode": "source"
        },
        {
          "name": "tgt",
          "type": "Procedure",
          "mode": "target"
        }
      ],
      "rule": [
        {
          "name": "identifier",
          "source": [
            {
              "context": "src",
              "element": "entryId",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "identifier.value",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "identifierSystem",
          "source": [
            {
              "context": "src",
              "element": "entryId",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "identifier.system",
              "transform": "evaluate",
              "parameter": [
                {
                  "valueString": "'https://example.org/fhir/sid/ccda-entry'"
                }
              ]
            }
          ]
        },
        {
          "name": "completedStatus",
          "source": [
            {
              "context": "src",
              "element": "entryId",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "status",
              "transform": "evaluate",
              "parameter": [
                {
                  "valueString": "'completed'"
                }
              ]
            }
          ]
        },
        {
          "name": "procedureCode",
          "source": [
            {
              "context": "src",
              "element": "code",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "code.coding",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "performed",
          "source": [
            {
              "context": "src",
              "element": "effectiveTime",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "performedDateTime",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "patientIdentifier",
          "source": [
            {
              "context": "src",
              "element": "subjectIdentifier",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "subject.identifier.value",
              "transform": "copy"
            }
          ]
        }
      ]
    }
  ]
}
