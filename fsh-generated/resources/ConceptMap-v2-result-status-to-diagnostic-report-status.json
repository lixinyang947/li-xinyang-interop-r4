{
  "resourceType": "ConceptMap",
  "id": "v2-result-status-to-diagnostic-report-status",
  "url": "https://example.org/fhir/li-xinyang-interop-r4/ConceptMap/v2-result-status-to-diagnostic-report-status",
  "version": "0.1.0",
  "name": "V2ResultStatusToDiagnosticReportStatus",
  "title": "HL7 v2 Result Status to FHIR DiagnosticReport Status",
  "status": "draft",
  "experimental": true,
  "date": "2026-07-21",
  "publisher": "Xinyang Li",
  "description": "Representative OBR-25 status normalization.",
  "copyright": "© 2026 Xinyang Li. Draft technical specification.",
  "purpose": "Supports declarative status translation for diagnostic reports.",
  "sourceUri": "http://terminology.hl7.org/CodeSystem/v2-0085",
  "targetUri": "http://hl7.org/fhir/diagnostic-report-status",
  "group": [
    {
      "source": "http://terminology.hl7.org/CodeSystem/v2-0085",
      "target": "http://hl7.org/fhir/diagnostic-report-status",
      "element": [
        {
          "code": "F",
          "display": "Final results",
          "target": [
            {
              "equivalence": "equivalent",
              "code": "final",
              "display": "Final"
            }
          ]
        },
        {
          "code": "C",
          "display": "Record coming over is a correction",
          "target": [
            {
              "equivalence": "equivalent",
              "code": "corrected",
              "display": "Corrected"
            }
          ]
        },
        {
          "code": "P",
          "display": "Preliminary results",
          "target": [
            {
              "equivalence": "equivalent",
              "code": "preliminary",
              "display": "Preliminary"
            }
          ]
        },
        {
          "code": "R",
          "display": "Results entered -- not verified",
          "target": [
            {
              "equivalence": "inexact",
              "code": "registered",
              "display": "Registered",
              "comment": "The FHIR registered state is used pending verification."
            }
          ]
        },
        {
          "code": "X",
          "display": "Results cannot be obtained",
          "target": [
            {
              "equivalence": "inexact",
              "code": "cancelled",
              "display": "Cancelled",
              "comment": "No-result status is represented as cancelled."
            }
          ]
        }
      ]
    }
  ]
}
