{
  "resourceType": "StructureMap",
  "id": "ccda-medication-to-medicationstatement",
  "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureMap/ccda-medication-to-medicationstatement",
  "version": "0.1.0",
  "name": "CCDAMedicationToMedicationStatement",
  "title": "C-CDA Medication Entry to HITC Canonical MedicationStatement",
  "status": "draft",
  "experimental": true,
  "date": "2026-07-21",
  "publisher": "Xinyang Li",
  "description": "XPath-extracted C-CDA medication entry to MedicationStatement.",
  "copyright": "© 2026 Xinyang Li. Draft technical specification.",
  "purpose": "Supports medication history exchange; Phase 2 applies RxNorm/NDC reconciliation.",
  "structure": [
    {
      "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureDefinition/HITCCCDAEntry",
      "mode": "source",
      "alias": "CCDAEntry",
      "documentation": "Normalized logical input model for the source segment or C-CDA entry."
    },
    {
      "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureDefinition/hitc-canonical-medication-statement",
      "mode": "target",
      "alias": "MedicationStatement",
      "documentation": "Strict-at-core canonical FHIR R4 target profile."
    }
  ],
  "group": [
    {
      "name": "CCDAMedicationToMedicationStatement",
      "typeMode": "types",
      "documentation": "Phase 1 structural mapping. Terminology translation, UCUM normalization, ISO 8601 normalization, and value-set validation occur in Phase 2 unless explicitly invoked by a translate rule.",
      "input": [
        {
          "name": "src",
          "type": "HITCCCDAEntry",
          "mode": "source"
        },
        {
          "name": "tgt",
          "type": "MedicationStatement",
          "mode": "target"
        }
      ],
      "rule": [
        {
          "name": "identifier",
          "source": [
            {
              "context": "src",
              "element": "entryId",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "identifier.value",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "identifierSystem",
          "source": [
            {
              "context": "src",
              "element": "entryId",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "identifier.system",
              "transform": "evaluate",
              "parameter": [
                {
                  "valueString": "'https://example.org/fhir/sid/ccda-entry'"
                }
              ]
            }
          ]
        },
        {
          "name": "activeStatus",
          "source": [
            {
              "context": "src",
              "element": "entryId",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "status",
              "transform": "evaluate",
              "parameter": [
                {
                  "valueString": "'active'"
                }
              ]
            }
          ]
        },
        {
          "name": "medicationCode",
          "source": [
            {
              "context": "src",
              "element": "code",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "medicationCodeableConcept.coding",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "effectiveTime",
          "source": [
            {
              "context": "src",
              "element": "effectiveTime",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "effectiveDateTime",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "assertedDate",
          "source": [
            {
              "context": "src",
              "element": "effectiveTime",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "dateAsserted",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "patientIdentifier",
          "source": [
            {
              "context": "src",
              "element": "subjectIdentifier",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "subject.identifier.value",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "authorIdentifier",
          "source": [
            {
              "context": "src",
              "element": "authorIdentifier",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "informationSource.identifier.value",
              "transform": "copy"
            }
          ]
        }
      ]
    }
  ]
}
