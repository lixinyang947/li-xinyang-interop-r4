{
  "resourceType": "StructureMap",
  "id": "v2-obr-to-diagnosticreport",
  "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureMap/v2-obr-to-diagnosticreport",
  "version": "0.1.0",
  "name": "V2OBRToDiagnosticReport",
  "title": "HL7 v2 OBR to HITC Canonical DiagnosticReport",
  "status": "draft",
  "experimental": true,
  "date": "2026-07-21",
  "publisher": "Xinyang Li",
  "description": "Declarative structural mapping from OBR to DiagnosticReport.",
  "copyright": "© 2026 Xinyang Li. Draft technical specification.",
  "purpose": "Supports ORU result grouping; Observation result references are attached by the orchestration layer.",
  "structure": [
    {
      "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureDefinition/HITCV2OBR",
      "mode": "source",
      "alias": "V2OBR",
      "documentation": "Normalized logical input model for the source segment or C-CDA entry."
    },
    {
      "url": "https://example.org/fhir/li-xinyang-interop-r4/StructureDefinition/hitc-canonical-diagnostic-report",
      "mode": "target",
      "alias": "DiagnosticReport",
      "documentation": "Strict-at-core canonical FHIR R4 target profile."
    }
  ],
  "group": [
    {
      "name": "V2OBRToDiagnosticReport",
      "typeMode": "types",
      "documentation": "Phase 1 structural mapping. Terminology translation, UCUM normalization, ISO 8601 normalization, and value-set validation occur in Phase 2 unless explicitly invoked by a translate rule.",
      "input": [
        {
          "name": "src",
          "type": "HITCV2OBR",
          "mode": "source"
        },
        {
          "name": "tgt",
          "type": "DiagnosticReport",
          "mode": "target"
        }
      ],
      "rule": [
        {
          "name": "reportIdentifier",
          "source": [
            {
              "context": "src",
              "element": "fillerOrderNumber",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "identifier.value",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "identifierSystem",
          "source": [
            {
              "context": "src",
              "element": "fillerOrderNumber",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "identifier.system",
              "transform": "evaluate",
              "parameter": [
                {
                  "valueString": "'https://example.org/fhir/sid/diagnostic-report'"
                }
              ]
            }
          ]
        },
        {
          "name": "reportCode",
          "source": [
            {
              "context": "src",
              "element": "universalServiceIdentifier",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "code.coding",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "effectiveTime",
          "source": [
            {
              "context": "src",
              "element": "observationDateTime",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "effectiveDateTime",
              "transform": "copy"
            }
          ]
        },
        {
          "name": "reportStatus",
          "source": [
            {
              "context": "src",
              "element": "resultStatus",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "status",
              "transform": "translate",
              "parameter": [
                {
                  "valueId": "v"
                },
                {
                  "valueString": "https://example.org/fhir/li-xinyang-interop-r4/ConceptMap/v2-result-status-to-diagnostic-report-status"
                },
                {
                  "valueString": "code"
                }
              ]
            }
          ]
        },
        {
          "name": "category",
          "source": [
            {
              "context": "src",
              "element": "diagnosticServiceSectionId",
              "variable": "v"
            }
          ],
          "target": [
            {
              "context": "tgt",
              "contextType": "variable",
              "element": "category.coding.code",
              "transform": "copy"
            }
          ]
        }
      ]
    }
  ]
}
